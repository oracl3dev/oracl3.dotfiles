{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",

  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [

        {
          "type": "path",
          "style": "plain",
          "foreground": "#7aa2f7",
          "properties": {
            "style": "folder"
          }
        },

        {
          "type": "git",
          "style": "plain",
          "foreground": "#a6e3a1",
          "properties": {
            "display_status": true
          }
        }

      ]
    }
  ],

  "final_space": true
}
